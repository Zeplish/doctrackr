# Database
POSTGRES_DB=doctrackr
POSTGRES_USER=doctrackr
POSTGRES_PASSWORD=changeme

# API Server
DATABASE_URL=postgresql://doctrackr:changeme@db:5432/doctrackr
SESSION_SECRET=replace-with-a-long-random-string
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
NODE_ENV=production
PORT=8080

# Proxy (port exposed on the host)
EXPOSE_PORT=80
